#!/usr/bin/env bash
#==============================================================================
# deskpi-config — interactive fan-speed configuration utility for DeskPi Pro
# https://github.com/DeskPi-Team/deskpi
#
# Talks to the DeskPi Pro daughter-board MCU over /dev/ttyUSB0 (a CH340
# enumerated by the dwc2 host-mode overlay) using short, fixed tokens:
#
#   pwm_000  fan off
#   pwm_025  fan at 25 %
#   pwm_050  fan at 50 %
#   pwm_075  fan at 75 %
#   pwm_100  fan at 100 %
#
# The companion pwmFanControl daemon reads CPU temperature and writes the
# correct token automatically; this tool is for manual override and for
# adjusting the temperature→PWM curve.
#
# Picking a manual speed (options 1-5) stops the daemon so the override
# sticks. Option 7 starts the daemon again with the built-in defaults.
# Option 6 writes a custom temperature→PWM curve to /etc/deskpi.conf.
#==============================================================================
set -euo pipefail

SERIAL_PORT="/dev/ttyUSB0"
FAN_SERVICE="deskpi.service"
CONF_FILE="/etc/deskpi.conf"

# ---- pretty-print helpers -------------------------------------------------
if [ -t 1 ] && command -v tput >/dev/null && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
    C_RESET=$'\e[0m'
    C_BOLD=$'\e[1m'
    C_DIM=$'\e[2m'
    C_RED=$'\e[31m'
    C_GREEN=$'\e[32m'
    C_YELLOW=$'\e[33m'
    C_BLUE=$'\e[34m'
    C_CYAN=$'\e[36m'
else
    C_RESET=""; C_BOLD=""; C_DIM=""
    C_RED=""; C_GREEN=""; C_YELLOW=""; C_BLUE=""; C_CYAN=""
fi

say()  { printf '%s==>%s %s\n' "$C_BOLD$C_CYAN" "$C_RESET" "$*"; }
ok()   { printf '%s[ OK ]%s %s\n' "$C_GREEN"        "$C_RESET" "$*"; }
warn() { printf '%s[WARN]%s %s\n' "$C_YELLOW"       "$C_RESET" "$*" >&2; }
fail() { printf '%s[FAIL]%s %s\n' "$C_RED"          "$C_RESET" "$*" >&2; }

banner() {
    printf '%s' "$C_BOLD$C_BLUE"
    cat <<'BANNER'
 ____  _____ ____  ____ ___      _____ _    _   _
|  _ \| ____/ ___||  _ \_ _|    |  ___/ \  | \ | |
| | | |  _| \___ \| |_) | |_____| |_ / _ \ |  \| |
| |_| | |___ ___) |  __/| |_____|  _/ ___ \| |\  |
|____/|_____|____/|_|  |___|    |_|/_/   \_\_| \_|

BANNER
    printf '%s' "$C_RESET"
    printf '   %sFan-speed configuration utility for DeskPi Pro%s\n' "$C_DIM" "$C_RESET"
    printf '   %sgithub.com/DeskPi-Team/deskpi%s\n\n' "$C_DIM" "$C_RESET"
}

# ---- preflight ------------------------------------------------------------
if [ "$(id -u)" -ne 0 ]; then
    warn "deskpi-config is best run with sudo (it needs to start/stop systemd units and write $CONF_FILE)."
fi

if [ ! -e "$SERIAL_PORT" ]; then
    fail "$SERIAL_PORT is missing. Is the dwc2 overlay enabled and the DeskPi Pro plugged in?"
    warn "Try:  sudo raspi-config  -> Interface Options -> Serial Port"
    warn "And confirm  dtoverlay=dwc2,dr_mode=host  is in /boot/firmware/config.txt"
    exit 1
fi

# ---- pwm writer -----------------------------------------------------------
# Writes the bare token to the UART. echo would add a trailing newline which
# the MCU does not want — use printf.
set_pwm() {
    local token="$1"
    if ! printf '%s' "$token" > "$SERIAL_PORT" 2>/dev/null; then
        fail "Failed to write '$token' to $SERIAL_PORT"
        return 1
    fi
    return 0
}

# ---- daemon helpers -------------------------------------------------------
fan_daemon_active() {
    systemctl is-active --quiet "$FAN_SERVICE" 2>/dev/null
}

stop_daemon() {
    if fan_daemon_active; then
        sudo systemctl stop "$FAN_SERVICE" 2>/dev/null || {
            warn "Failed to stop $FAN_SERVICE — manual override may be overwritten within ~1 s."
            return 1
        }
    fi
    return 0
}

start_daemon() {
    if ! fan_daemon_active; then
        sudo systemctl start "$FAN_SERVICE" 2>/dev/null || {
            warn "Failed to start $FAN_SERVICE — check: journalctl -u $FAN_SERVICE"
            return 1
        }
    fi
    return 0
}

# ---- current temperature --------------------------------------------------
current_temp() {
    if command -v vcgencmd >/dev/null; then
        vcgencmd measure_temp 2>/dev/null || echo "n/a"
    else
        echo "n/a"
    fi
}

# ---- temperature→PWM curve wizard ----------------------------------------
set_curve() {
    say "Define a 4-step temperature→PWM curve"
    printf '   %s(defaults: 40/25  50/50  65/75  75/100)%s\n\n' "$C_DIM" "$C_RESET"

    # install(1) truncates and creates with the requested mode in one step.
    sudo install -m 666 /dev/null "$CONF_FILE"

    local i temp speed
    for i in 1 2 3 4; do
        printf '   %sCPU temperature now: %s%s\n' \
            "$C_DIM" "$(current_temp)" "$C_RESET"
        while :; do
            read -r -p "   Temperature threshold #$i (degC, 0-110): " temp
            [[ "$temp" =~ ^[0-9]+$ ]] || { warn "Please enter a non-negative integer."; continue; }
            [ "$temp" -le 110 ] || { warn "Out of range (0-110)."; continue; }
            break
        done
        while :; do
            read -r -p "   Fan speed           #$i (0-100): " speed
            [[ "$speed" =~ ^[0-9]+$ ]] || { warn "Please enter a non-negative integer."; continue; }
            [ "$speed" -le 100 ] || { warn "Out of range (0-100)."; continue; }
            break
        done
        printf '%s\n%s\n' "$temp" "$speed" | sudo tee -a "$CONF_FILE" >/dev/null
        printf '\n'
    done
    ok "Wrote $CONF_FILE"
}

# ---- menu ----------------------------------------------------------------
menu() {
    banner
    printf '%sCurrent status%s\n' "$C_BOLD" "$C_RESET"
    printf '   CPU temperature : %s\n' "$(current_temp)"
    if fan_daemon_active; then
        if [ -e "$CONF_FILE" ]; then
            printf '   %-17s: %sactive%s (custom curve from %s)\n' \
                "$FAN_SERVICE" "$C_GREEN" "$C_RESET" "$CONF_FILE"
        else
            printf '   %-17s: %sactive%s (built-in defaults 40/25  50/50  65/75  75/100)\n' \
                "$FAN_SERVICE" "$C_GREEN" "$C_RESET"
        fi
    else
        printf '   %-17s: %sinactive%s (manual mode — fan stays at last PWM written)\n' \
            "$FAN_SERVICE" "$C_YELLOW" "$C_RESET"
    fi
    printf '\n'
    printf '%sManual fan-speed levels%s\n' "$C_BOLD" "$C_RESET"
    printf '   1)   25 %%   (pwm_025)\n'
    printf '   2)   50 %%   (pwm_050)\n'
    printf '   3)   75 %%   (pwm_075)\n'
    printf '   4)  100 %%   (pwm_100)\n'
    printf '   5)  OFF     (pwm_000)\n'
    printf '\n'
    printf '%sConfiguration%s\n' "$C_BOLD" "$C_RESET"
    printf '   6)  Custom temperature→PWM curve\n'
    printf '   7)  Restore automatic fan control\n'
    printf '\n'
    printf '   0)  Quit\n\n'
}

apply_level() {
    local pct="$1" token="$2"
    say "Switching to manual mode (stops $FAN_SERVICE so the override sticks)"
    stop_daemon || return 0
    say "Setting fan to ${pct} %%  (writing $token to MCU)"
    if set_pwm "$token"; then
        ok "Fan is now at ${pct} %% (manual mode)"
    fi
}

# ---- main loop ------------------------------------------------------------
while :; do
    menu
    read -r -p "Your choice: " choice
    case "${choice:-}" in
        1) apply_level 25  pwm_025 ;;
        2) apply_level 50  pwm_050 ;;
        3) apply_level 75  pwm_075 ;;
        4) apply_level 100 pwm_100 ;;
        5) apply_level 0   pwm_000 ;;
        6)
            say "Stopping $FAN_SERVICE to write a custom curve"
            stop_daemon || true
            set_curve
            if start_daemon; then
                ok "Restarted $FAN_SERVICE with the new curve"
            fi
            ;;
        7)
            say "Restoring automatic fan control"
            # Drop the custom curve so the daemon falls back to the
            # built-in default curve defined in pwmFanControl_v2.c.
            sudo rm -f "$CONF_FILE"
            if [ -e "$CONF_FILE" ]; then
                warn "Could not remove $CONF_FILE — check permissions."
            fi
            if start_daemon; then
                ok "$FAN_SERVICE is back in control (built-in default curve)"
            fi
            ;;
        0|q|Q)
            if ! fan_daemon_active; then
                warn "$FAN_SERVICE is still stopped. Restart it manually with:"
                warn "  sudo systemctl start $FAN_SERVICE"
                warn "(Or it will come back automatically on the next reboot.)"
            fi
            printf '\n%sBye.%s\n' "$C_DIM" "$C_RESET"
            exit 0
            ;;
        *)
            warn "Unknown choice: '$choice'.  Pick a number from the menu (0 to quit)."
            ;;
    esac
    printf '\n'
    if [ -t 0 ]; then
        read -r -p "Press <Enter> to return to the menu..." _
    fi
done